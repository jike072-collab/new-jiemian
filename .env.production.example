# Production 3106 example. Placeholder values only.
# Copy to the server's private environment file and replace every placeholder there.
# Do not create a server 3107 environment.

NODE_ENV=production
PORT=3106
APP_BIND_HOST=127.0.0.1
NEXT_TELEMETRY_DISABLED=1

ADMIN_PASSWORD=replace-with-strong-admin-password
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters

DATA_DIR=/srv/aohuang-ai/new-jiemian/data
UPLOADS_DIR=/srv/aohuang-ai/new-jiemian/uploads
RUNTIME_DIR=/srv/aohuang-ai/new-jiemian/.runtime

MEDIA_IMAGE_UPLOAD_LIMIT_MIB=10
MEDIA_VIDEO_UPLOAD_LIMIT_MIB=200
MEDIA_RETENTION_HOURS=24

STORAGE_WARNING_PERCENT=70
STORAGE_CRITICAL_PERCENT=80
STORAGE_VIDEO_BLOCK_PERCENT=85
STORAGE_MEDIA_BLOCK_PERCENT=90
STORAGE_EMERGENCY_PERCENT=95

WORKLOAD_USER_IMAGE_TASKS=2
WORKLOAD_USER_VIDEO_TASKS=1
WORKLOAD_USER_LARGE_UPLOADS=1
WORKLOAD_PROCESS_LARGE_VIDEO_IO=1
WORKLOAD_SITE_VIDEO_UPLOAD_PHASE=2
AUTH_LOGIN_FAILED_PER_IP_PER_MINUTE=5
AUTH_REGISTER_PER_IP_PER_HOUR=3
AUTH_ADMIN_PASSWORD_FAILED_PER_IP_PER_MINUTE=3

APP_DATABASE_URL=replace-with-private-postgresql-url
APP_DATABASE_EXPECTED_NAME=aohuang_app
APP_DATABASE_MAX_CONNECTIONS=5
APP_DATABASE_CONNECT_TIMEOUT_MS=5000
APP_DATABASE_QUERY_TIMEOUT_MS=10000
APP_DATABASE_IDLE_TIMEOUT_MS=30000
APP_AUTH_PERSISTENCE_MODE=postgres
APP_BILLING_PERSISTENCE_MODE=postgres
APP_TASK_BILLING_PERSISTENCE_MODE=postgres

LIBRARY_STORAGE_BACKEND=json
GENERATION_JOBS_BACKEND=existing
DATABASE_LIBRARY_DUAL_WRITE=false
DATABASE_LIBRARY_READ_ENABLED=false
DATABASE_JOBS_WRITE_ENABLED=false
DATABASE_IMPORT_DRY_RUN_ONLY=true

NEW_API_ENABLED=true
NEW_API_ENVIRONMENT=production
NEW_API_BASE_URL=https://new-api.example.invalid
NEW_API_TIMEOUT_MS=10000
NEW_API_MAX_RESPONSE_BYTES=1048576
NEW_API_ADMIN_USER_ID=replace-with-admin-user-id
NEW_API_ADMIN_ACCESS_TOKEN=replace-with-new-api-admin-token

IMAGE_API_URL=https://image-provider.example.invalid/v1/images/generations
IMAGE_MODEL=gpt-image-2
IMAGE_DISPLAY_NAME=gpt-image-2
IMAGE_MODEL_API_KEY=
IMAGE_ENDPOINT_TYPE=images-generations

IMG2_IMAGE_API_URL=https://image-edit-provider.example.invalid/v1/images/generations
IMG2_IMAGE_MODEL=image4k
IMG2_IMAGE_DISPLAY_NAME=img2-4K
IMG2_IMAGE_API_KEY=
IMG2_IMAGE_ENDPOINT_TYPE=images-generations

VIDEO_API_URL=https://video-provider.example.invalid/v1/videos/generations
VIDEO_MODEL=seedance2.0 720p-fast-sr
VIDEO_DISPLAY_NAME=seedance2.0 720p-fast-sr
VIDEO_MODEL_API_KEY=
VIDEO_ENDPOINT_TYPE=videos-generations

GROK_VIDEO_API_URL=https://grok-video-provider.example.invalid/v1/videos
GROK_VIDEO_MODEL=grok-video-1.0
GROK_VIDEO_DISPLAY_NAME=Grok video 1.0
GROK_VIDEO_API_KEY=

PROMPT_OPTIMIZER_API_URL=https://prompt-provider.example.invalid/chat/completions
PROMPT_OPTIMIZER_MODEL=deepseek-v4-flash
PROMPT_OPTIMIZER_DISPLAY_NAME=DeepSeek V4 Flash
PROMPT_OPTIMIZER_API_KEY=

VOLCENGINE_ACCESS_KEY_PAIR=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
VOLCENGINE_REGION=cn-north-1
VOLCENGINE_IMAGEX_ENDPOINT=https://imagex.volcengineapi.com
VOLCENGINE_IMAGEX_SERVICE_ID=
VOLCENGINE_IMAGEX_OUTPUT_DOMAIN=
VOLCENGINE_IMAGEX_OUTPUT_TPL=
VOLCENGINE_IMAGEX_WORKFLOW_TEMPLATE_ID=system_workflow_ai_super_resolution
VOLCENGINE_IMAGEX_MODEL_ID=ai_sr_model_v2
VOLCENGINE_VOD_ENDPOINT=https://vod.volcengineapi.com
VOLCENGINE_VOD_SPACE_NAME=
VOLCENGINE_VOD_OUTPUT_DOMAIN=
VOLCENGINE_VOD_TEMPLATE_1K=d6743c0cf75742719f74e0d5ad2c9ed6
VOLCENGINE_VOD_TEMPLATE_2K=966dad4845f24f1d8b3e4a5b68a88af2
VOLCENGINE_VOD_TEMPLATE_4K=feabc25e361e4c81b18849db2b206df3

PAYMENT_PRODUCTION_ENABLED=false
PAYMENT_PRODUCTION_WEBHOOK_SECRET=
