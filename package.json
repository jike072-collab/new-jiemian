{
  "name": "new-jiemian",
  "version": "0.1.0",
  "private": true,
  "description": "Aohuang AI local image and video generation studio",
  "author": "Aohuang AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jike072-collab/new-jiemian.git"
  },
  "homepage": "https://github.com/jike072-collab/new-jiemian",
  "bugs": {
    "url": "https://github.com/jike072-collab/new-jiemian/issues"
  },
  "keywords": [
    "ai-image",
    "ai-video",
    "local-studio",
    "nextjs",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "migrate": "node scripts/database/migrate.mjs up",
    "migrate:status": "node scripts/database/migrate.mjs status",
    "migrate:test": "npm run migrate && node scripts/database/test-schema.mjs && node scripts/database/test-client.mjs",
    "database:boundary": "node scripts/database/test-server-boundary.mjs",
    "db:health": "node scripts/database/migrate.mjs health"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
