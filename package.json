{
  "name": "new-jiemian",
  "version": "0.1.0",
  "private": true,
  "description": "Aohuang AI local image and video generation studio",
  "author": "Aohuang AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jike072-collab/new-jiemian.git"
  },
  "homepage": "https://github.com/jike072-collab/new-jiemian",
  "bugs": {
    "url": "https://github.com/jike072-collab/new-jiemian/issues"
  },
  "keywords": [
    "ai-image",
    "ai-video",
    "local-studio",
    "nextjs",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "dev:staging": "node scripts/with-staging-env.mjs node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/runtime-storage-preflight.mjs && node scripts/with-staging-env.mjs next dev -H 127.0.0.1",
    "build": "next build",
    "start": "npm run release:preflight && next start -H 127.0.0.1",
    "start:staging": "node scripts/start-staging.mjs",
    "start:next": "next start -H 127.0.0.1",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:runtime-isolation": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-runtime-data-isolation.mjs && node scripts/test-staging-start-preflight.mjs",
    "check:runtime-paths": "node scripts/check-runtime-path-usage.mjs",
    "test:staging-smoke": "node scripts/test-staging-smoke.mjs",
    "test:stage2-ui-acceptance": "node scripts/test-stage2-ui-acceptance.mjs",
    "test:stage3-studio-regression": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-stage3-studio-regression.mjs",
    "test:stage4-provider-health": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-stage4-provider-health.mjs",
    "test:release-artifact-cleanliness": "node scripts/test-release-artifact-cleanliness.mjs",
    "test:stage5-error-diagnostics": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/test-stage5-error-diagnostics.mjs",
    "check:release-test-artifact-isolation": "node scripts/check-release-test-artifact-isolation.mjs",
    "audit:production-readiness": "node scripts/audit-production-readiness.mjs",
    "check:studio-api-contracts": "node scripts/check-studio-api-contracts.mjs",
    "test:ops": "node scripts/test-ops-service.mjs && node scripts/test-active-release-atomic.mjs",
    "test:rollback-drill": "node scripts/test-full-rollback-drill.mjs",
    "service:status": "node scripts/ops/service-status.mjs",
    "service:health": "node scripts/ops/health-check.mjs",
    "service:start:staging": "node scripts/ops/start-service.mjs staging",
    "service:start:production": "node scripts/ops/start-service.mjs production",
    "service:stop:staging": "node scripts/ops/stop-service.mjs staging",
    "service:stop:production": "node scripts/ops/stop-service.mjs production",
    "service:watchdog:staging": "node scripts/ops/watchdog-service.mjs staging",
    "service:watchdog:production": "node scripts/ops/watchdog-service.mjs production",
    "deploy:staging": "node scripts/ops/deploy-service.mjs staging",
    "deploy:production": "node scripts/ops/deploy-service.mjs production",
    "check": "npm run lint && npm run typecheck && npm run test:runtime-isolation && npm run check:runtime-paths && npm run test:security-release && npm run check:studio-api-contracts && npm run test:stage3-studio-regression -- --skip-runtime && npm run test:stage4-provider-health && npm run test:release-artifact-cleanliness && npm run test:stage5-error-diagnostics && npm run check:release-test-artifact-isolation && npm run test:ops && npm run test:rollback-drill && npm run build",
    "migrate": "node scripts/database/migrate.mjs up",
    "migrate:status": "node scripts/database/migrate.mjs status",
    "migrate:test": "npm run migrate && node scripts/database/test-schema.mjs && node scripts/database/test-client.mjs",
    "migrate:auth-data:dry-run": "node scripts/database/auth-data-migration.mjs dry-run",
    "migrate:auth-data:apply": "node scripts/database/auth-data-migration.mjs apply --confirm-apply",
    "migrate:auth-data:verify": "node scripts/database/auth-data-migration.mjs verify",
    "verify:auth-persistence": "node scripts/database/verify-auth-persistence.mjs",
    "test:auth-persistence": "node scripts/database/test-auth-persistence.mjs",
    "database:boundary": "node scripts/database/test-server-boundary.mjs",
    "db:health": "node scripts/database/migrate.mjs health",
    "test:prompt-optimizer": "node scripts/test-prompt-optimizer.mjs",
    "test:security-release": "node scripts/test-security-release.mjs",
    "release:preflight": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/release-preflight.mjs",
    "security:release-check": "node scripts/security-release-check.mjs",
    "start:release": "npm start"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
