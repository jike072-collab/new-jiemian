#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
DEPLOY_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

usage() {
  echo "Usage: $0 [--input <log-file> --output <log-file>]" >&2
  exit 1
}

INPUT=
OUTPUT=

while [ "$#" -gt 0 ]; do
  case "$1" in
    --input)
      shift
      [ "$#" -gt 0 ] || usage
      INPUT=$1
      ;;
    --output)
      shift
      [ "$#" -gt 0 ] || usage
      OUTPUT=$1
      ;;
    *)
      usage
      ;;
  esac
  shift
done

if { [ -n "$INPUT" ] && [ -z "$OUTPUT" ]; } || { [ -z "$INPUT" ] && [ -n "$OUTPUT" ]; }; then
  usage
fi
[ -z "$INPUT" ] || [ -f "$INPUT" ] || { echo "Missing input log: $INPUT" >&2; exit 1; }

REDACT_SCRIPT=${NEW_API_REDACT_LOGS_SCRIPT:-"$DEPLOY_DIR/../../scripts/ops/redact-new-api-logs.mjs"}

if [ -n "$INPUT" ]; then
  node "$REDACT_SCRIPT" --input "$INPUT" --output "$OUTPUT"
else
  node "$REDACT_SCRIPT"
fi
