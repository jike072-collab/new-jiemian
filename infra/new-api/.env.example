# New API test deployment
#
# Copy this file to `.env` and replace every placeholder before starting the stack.
# Never commit `.env`, backups, or runtime data.

# Official image pin from B03/B05 verification
NEW_API_IMAGE=calciumion/new-api:v1.0.0-rc.11@sha256:bd30213d808857bb569ef47d3c9209d061a66ea089c2472ef46ce51e75517f19

# Host bind and service port. Keep the bind address local unless a private test network is required.
NEW_API_BIND_ADDRESS=127.0.0.1
NEW_API_PORT=3000
PORT=3000

# Runtime
TZ=Asia/Shanghai
NODE_TYPE=master
NODE_NAME=new-api-test-1
LOG_LEVEL=info
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Database
POSTGRES_DB=new_api_test
POSTGRES_USER=new_api_test
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
SQL_DSN=postgresql://new_api_test:replace-with-a-strong-postgres-password@postgres:5432/new_api_test?sslmode=disable

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_CONN_STRING=redis://:replace-with-a-strong-redis-password@redis:6379/0

# Session and crypto secrets
SESSION_SECRET=replace-with-a-strong-session-secret
CRYPTO_SECRET=replace-with-a-strong-crypto-secret

# Test administrator bootstrap values for the first /api/setup call.
# Username must be 12 characters or fewer and password must be 8 characters or longer.
ADMIN_USERNAME=testroot
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_CONFIRM_PASSWORD=replace-with-a-strong-admin-password
ADMIN_SELF_USE_MODE_ENABLED=true
ADMIN_DEMO_SITE_ENABLED=false
