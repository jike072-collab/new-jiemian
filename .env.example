# Optional admin password. If omitted, the providers API is intended for local use only.
ADMIN_PASSWORD=

# 3106 正式环境示例
# PORT=3106

# 3107 测试环境示例
# PORT=3107

# Runtime storage directories. Defaults are data/ and uploads/.
# 3107 测试环境建议显式隔离：
# DATA_DIR=data-staging
# UPLOADS_DIR=uploads-staging
#
# 3106 正式环境可保留默认值，或显式指定正式目录：
# DATA_DIR=data
# UPLOADS_DIR=uploads

# Optional server-side upload caps, in MiB. These may lower the defaults only.
# Image uploads default to 10MiB. Video upscale uploads default to 200MiB.
# Values above the 256MiB hard cap, or above the default, fall back to the safe default.
# MEDIA_IMAGE_UPLOAD_LIMIT_MIB=10
# MEDIA_VIDEO_UPLOAD_LIMIT_MIB=200

# Generated media retention. Defaults to 24 hours; valid range is 1-168.
# MEDIA_RETENTION_HOURS=24

# Optional New API server-side BFF integration.
# These values are read only by server code. Never expose admin values to the browser.
NEW_API_ENABLED=false
NEW_API_ENVIRONMENT=test
NEW_API_BASE_URL=http://127.0.0.1:3000
NEW_API_TIMEOUT_MS=10000
NEW_API_MAX_RESPONSE_BYTES=1048576
NEW_API_ADMIN_USER_ID=
NEW_API_ADMIN_ACCESS_TOKEN=

# Optional application PostgreSQL database.
# This is separate from the New API database and must remain server-only.
APP_DATABASE_URL=
APP_DATABASE_EXPECTED_NAME=aohuang_app
APP_DATABASE_MAX_CONNECTIONS=5
APP_DATABASE_CONNECT_TIMEOUT_MS=5000
APP_DATABASE_QUERY_TIMEOUT_MS=10000
APP_DATABASE_IDLE_TIMEOUT_MS=30000

# Auth persistence mode.
# Development can stay on json. Production must set this explicitly and must not silently fall back.
# BP-01B adds postgres and dual support, but production PostgreSQL primary writes still require release approval.
APP_AUTH_PERSISTENCE_MODE=json

# Optional defaults loaded before local data/providers.json exists.
IMAGE_API_URL=https://www.right.codes/draw/v1/images/generations
IMAGE_MODEL=gpt-image-2
IMAGE_MODEL_API_KEY=
IMAGE_ENDPOINT_TYPE=images-generations

# Optional img2/image4k image generation channel. Configure the real key locally or in the admin provider page.
IMG2_IMAGE_API_URL=https://api.nianhua.store/v1/images/generations
IMG2_IMAGE_MODEL=image4k
IMG2_IMAGE_DISPLAY_NAME=img2-4K
IMG2_IMAGE_API_KEY=
IMG2_IMAGE_ENDPOINT_TYPE=images-generations

VIDEO_API_URL=https://clmm-mall.top/v1/videos/generations
VIDEO_MODEL=seedance2.0 720p-fast-sr
VIDEO_MODEL_API_KEY=
VIDEO_ENDPOINT_TYPE=videos-generations

# Optional channels copied from the old codex_sp project.
# They are documented for later customer/account workflows and are not used by the current generator yet.
VISION_API_URL=https://right.codes/gemini
VISION_MODEL=gemini-2.5-flash
VISION_MODEL_API_KEY=

TEXT_API_URL=https://api.deepseek.com/chat/completions
TEXT_MODEL=deepseek-v4-pro
TEXT_MODEL_API_KEY=

# Optional local OpenAI-compatible proxy presets from codex_sp.
SUB2API_BASE_URL=http://127.0.0.1:8080/v1
SUB2API_CHAT_API_URL=http://127.0.0.1:8080/v1/chat/completions
SUB2API_IMAGE_API_URL=http://127.0.0.1:8080/v1/images/generations
SUB2API_VIDEO_API_URL=http://127.0.0.1:8080/v1/videos/generations

# Volcengine ImageX/VOD upscale channels. Put real credentials in local env or the admin provider page.
VOLCENGINE_ACCESS_KEY_PAIR=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=
VOLCENGINE_REGION=cn-north-1
VOLCENGINE_IMAGEX_ENDPOINT=https://imagex.volcengineapi.com
VOLCENGINE_IMAGEX_SERVICE_ID=
VOLCENGINE_IMAGEX_OUTPUT_DOMAIN=
VOLCENGINE_IMAGEX_OUTPUT_TPL=
VOLCENGINE_IMAGEX_WORKFLOW_TEMPLATE_ID=system_workflow_ai_super_resolution
VOLCENGINE_IMAGEX_MODEL_ID=ai_sr_model_v2
VOLCENGINE_VOD_ENDPOINT=https://vod.volcengineapi.com
VOLCENGINE_VOD_SPACE_NAME=
VOLCENGINE_VOD_OUTPUT_DOMAIN=
VOLCENGINE_VOD_TEMPLATE_1K=d6743c0cf75742719f74e0d5ad2c9ed6
VOLCENGINE_VOD_TEMPLATE_2K=966dad4845f24f1d8b3e4a5b68a88af2
VOLCENGINE_VOD_TEMPLATE_4K=feabc25e361e4c81b18849db2b206df3
