# Aohuang AI Nginx site template for one production instance on 3106.
# Replace aohuang.example.com and certificate paths before enabling.
# 3106 must not listen on a public interface; Nginx proxies only to 127.0.0.1.

# Rate-limit zones live in deploy/linux/nginx-limits.conf.example and should be
# installed into the nginx http context, for example at
# /etc/nginx/conf.d/aohuang-ai-limits.conf.
# Nginx is a coarse second layer of IP protection; the app still enforces exact
# per-user and hourly limits.

upstream aohuang_ai_3106 {
    server 127.0.0.1:3106;
    keepalive 16;
}

server {
    listen 80;
    listen [::]:80;
    server_name aohuang.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/letsencrypt;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name aohuang.example.com;

    ssl_certificate /etc/letsencrypt/live/aohuang.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/aohuang.example.com/privkey.pem;

    # Enable only after HTTPS is verified for the final domain.
    # add_header Strict-Transport-Security "max-age=15552000; includeSubDomains" always;

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # App default video upload limit is 200MiB. Keep Nginx slightly above that
    # and below the app hard cap of 256MiB.
    client_max_body_size 220m;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "";
    proxy_connect_timeout 30s;
    proxy_send_timeout 900s;
    proxy_read_timeout 900s;
    send_timeout 900s;

    location ~ /\.(?!well-known) {
        deny all;
    }

    location ~* (^|/)\.env {
        deny all;
    }

    location ~* ^/(data|uploads|runtime|backups)(/|$) {
        deny all;
    }

    location = /api/auth/login {
        limit_req zone=aohuang_login burst=5 nodelay;
        add_header Cache-Control "no-store" always;
        proxy_pass http://aohuang_ai_3106;
    }

    location = /api/auth/register {
        limit_req zone=aohuang_register burst=3 nodelay;
        add_header Cache-Control "no-store" always;
        proxy_pass http://aohuang_ai_3106;
    }

    location ~ ^/api/admin/ {
        limit_req zone=aohuang_admin burst=3 nodelay;
        add_header Cache-Control "no-store" always;
        proxy_pass http://aohuang_ai_3106;
    }

    location ~ ^/api/(generate/(image|video)|upscale/(image|video))/?$ {
        limit_req zone=aohuang_generate burst=10 nodelay;
        add_header Cache-Control "no-store" always;
        proxy_buffering off;
        proxy_request_buffering on;
        proxy_pass http://aohuang_ai_3106;
    }

    location /api/ {
        add_header Cache-Control "no-store" always;
        proxy_no_cache 1;
        proxy_cache_bypass 1;
        proxy_pass http://aohuang_ai_3106;
    }

    location /_next/static/ {
        proxy_pass http://aohuang_ai_3106;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    location / {
        proxy_pass http://aohuang_ai_3106;
    }
}
