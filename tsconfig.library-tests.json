{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": false,
    "emitDeclarationOnly": false,
    "incremental": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist/library-tests",
    "rootDir": ".",
    "target": "ES2022",
    "tsBuildInfoFile": "dist/library-tests.tsbuildinfo"
  },
  "include": [
    "src/lib/server/library.ts",
    "src/lib/server/paths.ts",
    "src/lib/server/runtime-paths.ts",
    "src/lib/server/types.ts",
    "src/lib/server/database/**/*.ts",
    "src/lib/server/tunneltest-limits.ts",
    "src/lib/server/tunneltest-reference-images.ts",
    "src/lib/server/quota/types.ts",
    "src/lib/server/__tests__/library-ownership.test.ts",
    "src/lib/server/__tests__/tunneltest-limits.test.ts",
    "src/lib/server/__tests__/tunneltest-reference-images.test.ts"
  ]
}
